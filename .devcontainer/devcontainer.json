{
  "name": "SpotRaceJava",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "redhat.java",
        "vscjava.vscode-maven"
      ]
    }
  },

  "forwardPorts": [8080],

  "postCreateCommand": "./mvnw clean compile",

  "remoteUser": "vscode"
}